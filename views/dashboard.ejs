<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AGRI AI</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 20px; }
        .dashboard-card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .card-icon { font-size: 32px; margin-bottom: 10px; }
        .card-stats { font-size: 24px; font-weight: bold; color: #2196F3; margin: 10px 0; }
        .chart-container { position: relative; height: 300px; margin: 20px 0; }
        .chart-wrapper { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 20px; }
        .prediction-item { background: #f5f5f5; padding: 15px; border-radius: 5px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
        .severity-badge { padding: 5px 10px; border-radius: 20px; font-size: 12px; font-weight: bold; }
        .severity-low { background: #4CAF50; color: white; }
        .severity-medium { background: #FF9800; color: white; }
        .severity-high { background: #F44336; color: white; }
        .severity-critical { background: #9C27B0; color: white; }
        .action-btn { background: #2196F3; color: white; padding: 10px 15px; border: none; border-radius: 5px; cursor: pointer; }
        .action-btn:hover { background: #1976D2; }
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 20px; }
        .stat-box { background: white; padding: 20px; border-radius: 8px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .stat-value { font-size: 28px; font-weight: bold; color: #2196F3; }
        .stat-label { color: #666; margin-top: 5px; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">🌾 AGRI AI</div>
            <div class="nav-menu">
                <% if (isAuthenticated) { %>
                    <span class="nav-user">Welcome, <%= userName %>!</span>
                    <a href="/auth/logout" class="nav-logout">Logout</a>
                <% } else { %>
                    <span class="nav-user">Welcome, Guest!</span>
                    <a href="/auth/login" class="nav-login" style="background: #2196F3; color: white; padding: 8px 15px; border-radius: 5px; text-decoration: none;">Sign In</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="layout-with-sidebar">
        <aside class="sidebar">
            <div class="sidebar-header">Navigation</div>
            <ul class="sidebar-menu">
                <li><a href="/dashboard" class="menu-link active">📊 Dashboard</a></li>
                <li><a href="/dashboard/disease-detection" class="menu-link">🔬 Disease Detection</a></li>
                <li><a href="/dashboard/predictions" class="menu-link">📋 Predictions</a></li>
                <li><a href="/dashboard/crop-search" class="menu-link">🔍 Crop Search</a></li>
                <li><a href="/dashboard/crop-diseases" class="menu-link">🦠 Crop Diseases</a></li>
                <li><a href="/dashboard/food-crops" class="menu-link">🌱 Food Crops</a></li>
                <li><a href="/dashboard/crop-prices" class="menu-link">💰 Crop Prices</a></li>
                <li><a href="/dashboard/agricultural-seasons" class="menu-link">📅 Seasons</a></li>
                <li><a href="/dashboard/ai-tools" class="menu-link">🤖 AI Tools</a></li>
                <li><a href="/dashboard/research-topics" class="menu-link">📚 Research</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>📊 AGRI AI Dashboard</h1>
                <p>Track your predictions, analyze diseases, and get treatment recommendations</p>
            </div>

            <!-- Statistics Section -->
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-value"><%= summary.total_predictions || 0 %></div>
                    <div class="stat-label">Total Predictions</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value"><%= summary.unique_crops %></div>
                    <div class="stat-label">Crops Analyzed</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value"><%= summary.unique_diseases %></div>
                    <div class="stat-label">Diseases Detected</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value"><%= summary.avg_confidence %>%</div>
                    <div class="stat-label">Avg Confidence</div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="dashboard-grid">
                <div class="dashboard-card">
                    <div class="card-icon">🔬</div>
                    <h3>Detect Disease</h3>
                    <p>Upload an image to detect crop diseases using AI</p>
                    <a href="/dashboard/disease-detection" class="action-btn">Start Detection →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">📋</div>
                    <h3>View Predictions</h3>
                    <p>Review your prediction history and results</p>
                    <a href="/dashboard/predictions" class="action-btn">View History →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">🦠</div>
                    <h3>Learn Diseases</h3>
                    <p>Explore common crop diseases and treatments</p>
                    <a href="/dashboard/crop-diseases" class="action-btn">Explore →</a>
                </div>
            </div>

            <!-- Severity Distribution Chart -->
            <div class="chart-wrapper">
                <h3>Disease Severity Distribution</h3>
                <div class="chart-container">
                    <canvas id="severityChart"></canvas>
                </div>
            </div>

            <!-- Recent Predictions -->
            <div class="chart-wrapper">
                <h3>Recent Predictions</h3>
                <% if (analytics.predictions && analytics.predictions.length > 0) { %>
                    <div>
                        <% analytics.predictions.slice(0, 5).forEach(pred => { %>
                            <div class="prediction-item">
                                <div>
                                    <strong><%= pred.crop.charAt(0).toUpperCase() + pred.crop.slice(1) %></strong> - <%= pred.disease %>
                                    <br><small>Confidence: <%= (pred.confidence * 100).toFixed(1) %>%</small>
                                </div>
                                <span class="severity-badge severity-<%= pred.severity %>"><%= pred.severity.toUpperCase() %></span>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p>No predictions yet. <a href="/dashboard/disease-detection">Start by detecting a disease</a></p>
                <% } %>
            </div>

            <!-- Top Diseases Detected -->
            <% if (analytics.predictions && analytics.predictions.length > 0) { %>
                <div class="chart-wrapper">
                    <h3>Top Diseases Detected</h3>
                    <div class="chart-container">
                        <canvas id="diseasesChart"></canvas>
                    </div>
                </div>
            <% } %>
        </main>
    </div>

    <% 
        const chartConfig = {
            severity: summary.severity_distribution || {low: 0, medium: 0, high: 0, critical: 0},
            diseases: (() => { 
                const m = {}; 
                if (analytics.predictions) {
                    analytics.predictions.forEach(p => { m[p.disease] = (m[p.disease] || 0) + 1; });
                }
                return m;
            })()
        };
    %>
    <!-- Chart configuration data -->
    <script type="application/json" id="chart-config">
<%- JSON.stringify(chartConfig) %>
    </script>
    <script>
        // Parse chart data from JSON
        const chartConfig = JSON.parse(document.getElementById('chart-config').textContent);
        const severityData = chartConfig.severity;
        const diseaseChartData = chartConfig.diseases;

        // Initialize Severity Chart
        setTimeout(() => {
            if (document.getElementById('severityChart')) {
                const severityCtx = document.getElementById('severityChart').getContext('2d');
                new Chart(severityCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Low', 'Medium', 'High', 'Critical'],
                        datasets: [{
                            data: [severityData.low, severityData.medium, severityData.high, severityData.critical],
                            backgroundColor: ['#4CAF50', '#FF9800', '#F44336', '#9C27B0'],
                            borderColor: '#fff',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }
        }, 100);

        // Initialize Diseases Chart
        setTimeout(() => {
            if (document.getElementById('diseasesChart') && Object.keys(diseaseChartData).length > 0) {
                const diseasesCtx = document.getElementById('diseasesChart').getContext('2d');
                new Chart(diseasesCtx, {
                    type: 'bar',
                    data: {
                        labels: Object.keys(diseaseChartData),
                        datasets: [{
                            label: 'Detections',
                            data: Object.values(diseaseChartData),
                            backgroundColor: '#2196F3',
                            borderColor: '#1976D2',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
        }, 100);
    </script>
                    <h3>Crop Diseases</h3>
                    <p>Learn about common crop diseases, symptoms, and treatment methods</p>
                    <a href="/dashboard/crop-diseases" class="card-link">View →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">🌱</div>
                    <h3>Food Crops</h3>
                    <p>Comprehensive list of food crops with seasonal information</p>
                    <a href="/dashboard/food-crops" class="card-link">View →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">💰</div>
                    <h3>Crop Prices</h3>
                    <p>Current market prices for various agricultural products</p>
                    <a href="/dashboard/crop-prices" class="card-link">View →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">📅</div>
                    <h3>Agricultural Seasons</h3>
                    <p>Information about different agricultural seasons and their characteristics</p>
                    <a href="/dashboard/agricultural-seasons" class="card-link">View →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">🤖</div>
                    <h3>AI Tools</h3>
                    <p>Advanced agricultural AI tools for modern farming</p>
                    <a href="/dashboard/ai-tools" class="card-link">View →</a>
                </div>

                <div class="dashboard-card">
                    <div class="card-icon">📚</div>
                    <h3>Research Topics</h3>
                    <p>Latest agriculture and AI research initiatives</p>
                    <a href="/dashboard/research-topics" class="card-link">View →</a>
                </div>
            </div>

            <div class="dashboard-stats">
                <h2>Quick Stats</h2>
                <div class="stats-grid">
                    <div class="stat-box">
                        <h4>Food Crops</h4>
                        <p class="stat-number">8</p>
                    </div>
                    <div class="stat-box">
                        <h4>Crop Diseases</h4>
                        <p class="stat-number">5</p>
                    </div>
                    <div class="stat-box">
                        <h4>AI Tools</h4>
                        <p class="stat-number">5</p>
                    </div>
                    <div class="stat-box">
                        <h4>Research Topics</h4>
                        <p class="stat-number">6</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <footer class="footer">
        <p>&copy; 2026 Agriculture Information Portal. All rights reserved.</p>
    </footer>
</body>
</html>
