<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Agriculture Info</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">🌾 Agriculture Info Portal</div>
            <div class="nav-menu">
                <span class="nav-user">Welcome, <%= userName %>!</span>
                <a href="/auth/logout" class="nav-logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="layout-with-sidebar">
        <aside class="sidebar">
            <div class="sidebar-header">Navigation</div>
            <ul class="sidebar-menu">
                <li><a href="/dashboard" class="menu-link">📊 Dashboard</a></li>
                <li><a href="/dashboard/crop-diseases" class="menu-link active">🦠 Crop Diseases</a></li>
                <li><a href="/dashboard/food-crops" class="menu-link">🌱 Food Crops</a></li>
                <li><a href="/dashboard/crop-prices" class="menu-link">💰 Crop Prices</a></li>
                <li><a href="/dashboard/agricultural-seasons" class="menu-link">📅 Seasons</a></li>
                <li><a href="/dashboard/ai-tools" class="menu-link">🤖 AI Tools</a></li>
                <li><a href="/dashboard/research-topics" class="menu-link">📚 Research</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1>🦠 Crop Diseases</h1>
                <p>Learn about common crop diseases, symptoms, treatment, and prevention methods</p>
            </div>

            <div class="content-container">
                <div class="diseases-grid">
                    <% diseases.forEach(disease => { %>
                        <div class="disease-card">
                            <div class="card-header">
                                <h3><%= disease.name %></h3>
                                <span class="badge"><%= disease.affectedCrop %></span>
                            </div>
                            <div class="card-content">
                                <div class="info-block">
                                    <strong>Symptoms:</strong>
                                    <p><%= disease.symptoms %></p>
                                </div>
                                <div class="info-block">
                                    <strong>Treatment:</strong>
                                    <p><%= disease.treatment %></p>
                                </div>
                                <div class="info-block">
                                    <strong>Prevention:</strong>
                                    <p><%= disease.prevention %></p>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </main>
    </div>

    <footer class="footer">
        <p>&copy; 2026 Agriculture Information Portal. All rights reserved.</p>
    </footer>
</body>
</html>
